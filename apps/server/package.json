{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bash -lc 'PORT_TO_USE=${PORT:-8000}; while lsof -i :$PORT_TO_USE >/dev/null 2>&1; do PORT_TO_USE=$((PORT_TO_USE + 1)); done; echo \"Using PORT=$PORT_TO_USE\"; PORT=$PORT_TO_USE bun run --hot src/index.ts'",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@my-better-t-app/db": "*",
    "@my-better-t-app/env": "*",
    "dotenv": "^17.2.2",
    "fluent-ffmpeg": "^2.1.3",
    "groq-sdk": "^0.3.3",
    "hono": "^4.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@my-better-t-app/config": "*",
    "@types/bun": "^1.3.4",
    "@types/fluent-ffmpeg": "^2.1.24",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
